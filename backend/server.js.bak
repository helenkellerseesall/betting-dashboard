  }

  const buildBestLegSlip = (legCount) => {
    return buildTierWithFallback(bestValueSources, legCount, [
      {
        maxPerPlayer: 1,
        maxPerGame: legCount >= 5 ? 1 : 2,
        minScore: legCount <= 2 ? 96 : legCount <= 4 ? 88 : 78,
        avoidFragile: true,
        forceUniquePlayers: true,
        blockSameGameStatSide: true,
        allowedPropTypes: ["Points", "Rebounds", "Assists", "Threes"]
      },
      {
        maxPerPlayer: 1,
        maxPerGame: legCount >= 5 ? 1 : 2,
        minScore: legCount <= 2 ? 88 : legCount <= 4 ? 80 : 70,
        avoidFragile: false,
        forceUniquePlayers: true,
        blockSameGameStatSide: true,
        allowedPropTypes: ["Points", "Rebounds", "Assists", "Threes"]
      },
      {
        maxPerPlayer: 1,
        maxPerGame: 2,
        minScore: legCount <= 2 ? 80 : legCount <= 4 ? 72 : 62,
        avoidFragile: false,
