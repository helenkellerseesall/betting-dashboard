function buildLiveDualBestAvailablePayload() {
  const elite = getAvailablePrimarySlateRows(oddsSnapshot.eliteProps || [])
  const strong = getAvailablePrimarySlateRows(oddsSnapshot.strongProps || [])
  const playable = getAvailablePrimarySlateRows(oddsSnapshot.playableProps || [])
  const best = getAvailablePrimarySlateRows(oddsSnapshot.bestProps || [])

  const availableCounts = {
    elite: {
      total: elite.length,
      fanduel: elite.filter((row) => row.book === "FanDuel").length,
      draftkings: elite.filter((row) => row.book === "DraftKings").length
    },
    strong: {
      total: strong.length,
      fanduel: strong.filter((row) => row.book === "FanDuel").length,
      draftkings: strong.filter((row) => row.book === "DraftKings").length
    },
    playable: {
      total: playable.length,
      fanduel: playable.filter((row) => row.book === "FanDuel").length,
      draftkings: playable.filter((row) => row.book === "DraftKings").length
    },
    best: {
      total: best.length,
      fanduel: best.filter((row) => row.book === "FanDuel").length,
      draftkings: best.filter((row) => row.book === "DraftKings").length
    }
  }

  // ONLY ML-weighted Highest Hit Rate tier (for winning with least chance to miss)
  return {
    availableCounts,
    highestHitRate2: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 2, buildHighestHitRateBookSlip("FanDuel", 2)), "Highest Hit Rate 2-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 2, buildHighestHitRateBookSlip("DraftKings", 2)), "Highest Hit Rate 2-Leg")
    },
    highestHitRate3: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 3, buildHighestHitRateBookSlip("FanDuel", 3)), "Highest Hit Rate 3-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 3, buildHighestHitRateBookSlip("DraftKings", 3)), "Highest Hit Rate 3-Leg")
    },
    highestHitRate4: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 4, buildHighestHitRateBookSlip("FanDuel", 4)), "Highest Hit Rate 4-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 4, buildHighestHitRateBookSlip("DraftKings", 4)), "Highest Hit Rate 4-Leg")
    },
    highestHitRate5: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 5, buildHighestHitRateBookSlip("FanDuel", 5)), "Highest Hit Rate 5-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 5, buildHighestHitRateBookSlip("DraftKings", 5)), "Highest Hit Rate 5-Leg")
    },
    highestHitRate6: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 6, buildHighestHitRateBookSlip("FanDuel", 6)), "Highest Hit Rate 6-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 6, buildHighestHitRateBookSlip("DraftKings", 6)), "Highest Hit Rate 6-Leg")
    },
    highestHitRate7: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 7, buildHighestHitRateBookSlip("FanDuel", 7)), "Highest Hit Rate 7-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 7, buildHighestHitRateBookSlip("DraftKings", 7)), "Highest Hit Rate 7-Leg")
    },
    highestHitRate8: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 8, buildHighestHitRateBookSlip("FanDuel", 8)), "Highest Hit Rate 8-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 8, buildHighestHitRateBookSlip("DraftKings", 8)), "Highest Hit Rate 8-Leg")
    },
    highestHitRate9: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 9, buildHighestHitRateBookSlip("FanDuel", 9)), "Highest Hit Rate 9-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 9, buildHighestHitRateBookSlip("DraftKings", 9)), "Highest Hit Rate 9-Leg")
    },
    highestHitRate10: {
      fanduel: makeSlipObject("FanDuel", withBookSlipFallback("FanDuel", 10, buildHighestHitRateBookSlip("FanDuel", 10)), "Highest Hit Rate 10-Leg"),
      draftkings: makeSlipObject("DraftKings", withBookSlipFallback("DraftKings", 10, buildHighestHitRateBookSlip("DraftKings", 10)), "Highest Hit Rate 10-Leg")
