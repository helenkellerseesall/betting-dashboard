}
function buildHighestHitRateBookSlip(book, targetLegCount) {
  const elite = sortRowsForMLHighestHitRate(
    filterRowsToPrimarySlate((oddsSnapshot.eliteProps || []).filter((r) => r.book === book))
  )
  const strong = sortRowsForMLHighestHitRate(
    filterRowsToPrimarySlate((oddsSnapshot.strongProps || []).filter((r) => r.book === book))
  )
  const playable = sortRowsForMLHighestHitRate(
    filterRowsToPrimarySlate((oddsSnapshot.playableProps || []).filter((r) => r.book === book))
  )

  const sources = [elite, strong, playable]
  const shared = {
    maxPerPlayer: 2,  // Relaxed from 1 to allow PRA + correlated props
    maxPerGame: 2,
    preferredBook: book,
    forceUniquePlayers: false,  // Relaxed - allow stat combinations
    blockSameGameStatSide: false,  // Relaxed - allow natural correlations
    allowedPropTypes: null  // NULL = ALL prop types (Points, Rebounds, Assists, Threes, PRA, etc.)
  }

  if (targetLegCount === 2) {
    return buildTierWithFallback(sources, 2, [
      { ...shared, minScore: 95, avoidFragile: true },
      { ...shared, minScore: 85, avoidFragile: false },
      { ...shared, minScore: 75, avoidFragile: false },
      { ...shared, minScore: 65, avoidFragile: false }
    ])
  }

  if (targetLegCount === 3) {
    return buildTierWithFallback(sources, 3, [
      { ...shared, minScore: 60, avoidFragile: false },  // Floor for 3-leg
      { ...shared, minScore: 50, avoidFragile: false },
      { ...shared, minScore: 40, avoidFragile: false },
      { ...shared, minScore: 30, avoidFragile: false }
    ])
  }

  if (targetLegCount === 4) {
    return buildTierWithFallback(sources, 4, [
      { ...shared, minScore: 55, avoidFragile: false },  // Floor for 4-leg
      { ...shared, minScore: 45, avoidFragile: false },
      { ...shared, minScore: 35, avoidFragile: false },
      { ...shared, minScore: 25, avoidFragile: false }
    ])
  }

  if (targetLegCount === 5) {
    return buildTierWithFallback(sources, 5, [
      { ...shared, minScore: 75, avoidFragile: false },
      { ...shared, minScore: 65, avoidFragile: false },
      { ...shared, minScore: 55, avoidFragile: false },
      { ...shared, minScore: 48, avoidFragile: false }
    ])
  }

  if (targetLegCount === 6) {
    return buildTierWithFallback(sources, 6, [
      { ...shared, minScore: 70, avoidFragile: false },
      { ...shared, minScore: 60, avoidFragile: false },
      { ...shared, minScore: 50, avoidFragile: false },
      { ...shared, minScore: 42, avoidFragile: false }
    ])
  }

  if (targetLegCount === 7) {
    return buildTierWithFallback(sources, 7, [
      { ...shared, minScore: 65, avoidFragile: false },
      { ...shared, minScore: 55, avoidFragile: false },
      { ...shared, minScore: 45, avoidFragile: false },
      { ...shared, minScore: 38, avoidFragile: false }
    ])
  }

  if (targetLegCount === 8) {
    return buildTierWithFallback(sources, 8, [
      { ...shared, minScore: 60, avoidFragile: false },
      { ...shared, minScore: 50, avoidFragile: false },
      { ...shared, minScore: 40, avoidFragile: false },
      { ...shared, minScore: 35, avoidFragile: false }
    ])
  }

  if (targetLegCount === 9) {
    return buildTierWithFallback(sources, 9, [
      { ...shared, minScore: 55, avoidFragile: false },
      { ...shared, minScore: 45, avoidFragile: false },
      { ...shared, minScore: 35, avoidFragile: false },
      { ...shared, minScore: 30, avoidFragile: false }
    ])
  }

  return buildTierWithFallback(sources, 10, [
    { ...shared, minScore: 50, avoidFragile: false },
    { ...shared, minScore: 40, avoidFragile: false },
    { ...shared, minScore: 30, avoidFragile: false },
    { ...shared, minScore: 25, avoidFragile: false }
  ])
}

function buildBestBookSlip(book, targetLegCount) {
  return buildTargetBookSlip(book, targetLegCount)
}

function getBookPrimaryRows(book) {
  const primaryBest = getAvailablePrimarySlateRows(oddsSnapshot.bestProps || [])
  const primaryElite = getAvailablePrimarySlateRows(oddsSnapshot.eliteProps || [])
  const primaryStrong = getAvailablePrimarySlateRows(oddsSnapshot.strongProps || [])
  const primaryPlayable = getAvailablePrimarySlateRows(oddsSnapshot.playableProps || [])

  const combined = dedupeSlipLegs([
    ...primaryBest,
    ...primaryElite,
    ...primaryStrong,
    ...primaryPlayable
  ]).filter(
    (row) => row.book === book && isSafeSlipAllowedPropType(row.propType)
  )

  return sortRowsForMLHighestHitRate(combined)
}

function fallbackBookSlip(book, targetLegCount) {
  const rows = getBookPrimaryRows(book)
  if (!rows.length) return []

  const exact = buildTierWithFallback([rows], targetLegCount, [
    {
      maxPerPlayer: 1,
      maxPerGame: targetLegCount <= 2 ? 1 : targetLegCount <= 4 ? 2 : 3,
      preferredBook: book,
      minScore: 0,
      avoidFragile: false,
      forceUniquePlayers: true,
      blockSameGameStatSide: targetLegCount <= 3,
      allowedPropTypes: ["Points", "Rebounds", "Assists", "Threes"]
    }
  ])

  if (exact.length === targetLegCount) return exact
  if (exact.length > 0) return exact

  for (let count = targetLegCount - 1; count >= 2; count -= 1) {
    const partial = buildTierWithFallback([rows], count, [
      {
        maxPerPlayer: 1,
        maxPerGame: count <= 2 ? 1 : count <= 4 ? 2 : 3,
        preferredBook: book,
        minScore: 0,
        avoidFragile: false,
        forceUniquePlayers: true,
        blockSameGameStatSide: count <= 3,
        allowedPropTypes: ["Points", "Rebounds", "Assists", "Threes"]
      }
    ])

    if (partial.length > 0) return partial
  }

  return []
}

function withBookSlipFallback(book, targetLegCount, legs) {
  const normalizedLegs = Array.isArray(legs)
    ? dedupeSlipLegs(legs).filter((row) => !shouldRemoveLegForPlayerStatus(row))
    : []

  if (normalizedLegs.length === targetLegCount) return normalizedLegs
  if (normalizedLegs.length > 0) return normalizedLegs

  const fallback = fallbackBookSlip(book, targetLegCount)
  const normalizedFallback = Array.isArray(fallback)
    ? dedupeSlipLegs(fallback).filter((row) => !shouldRemoveLegForPlayerStatus(row))
    : []

  if (normalizedFallback.length === targetLegCount) return normalizedFallback
  if (normalizedFallback.length > 0) return normalizedFallback

  return []
}

app.get("/api/best-available", (req, res) => {
  const payload = buildLiveDualBestAvailablePayload()

  if (!payload) {
    return res.status(503).json({
      ok: false,
      error: "bestAvailable not ready"
    })
  }

  return res.json({ bestAvailable: payload })
})

